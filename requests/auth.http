@baseUrl = http://localhost:8080

### Login as the seeded bootstrap admin
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@zeppelin.local",
  "password": "ChangeMe123!"
}

### Unauthenticated request - expect 401
GET {{baseUrl}}/api/users

### Authenticated request - expect 200 with the seeded admin
GET {{baseUrl}}/api/users
Authorization: Bearer {{login.response.body.accessToken}}

### Create a dentist
POST {{baseUrl}}/api/users
Authorization: Bearer {{login.response.body.accessToken}}
Content-Type: application/json

{
  "email": "dr.davit@zeppelin.local",
  "password": "DentistPass123!",
  "firstName": "Davit",
  "lastName": "Shengelia",
  "staffTitle": "DDS",
  "roles": ["Dentist"]
}

### Refresh - rotates the refresh token, old one becomes invalid
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{login.response.body.refreshToken}}"
}

### Logout - revokes the refresh token
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{login.response.body.refreshToken}}"
}
